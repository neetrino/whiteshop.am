{
  "name": "whiteshop.am",
  "version": "1.0.0",
  "private": true,
  "description": "WhiteShop.am — Next.js app at root, pnpm workspace",
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --no-turbo",
    "dev:clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\" && next dev",
    "prebuild": "cd shared/db && pnpm run db:generate",
    "prebuild:migrate": "node src/scripts/run-migrations.js",
    "build": "pnpm run prebuild && next build",
    "build:with-migrate": "pnpm run prebuild:migrate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 2000",
    "lint:next": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\"",
    "prisma:generate": "cd shared/db && pnpm run db:generate",
    "reset": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\" && cd shared/db && pnpm run db:generate",
    "db:generate": "pnpm --filter @white-shop/db db:generate",
    "db:push": "pnpm --filter @white-shop/db db:push",
    "db:migrate": "pnpm --filter @white-shop/db db:migrate",
    "db:studio": "pnpm --filter @white-shop/db db:studio",
    "db:seed": "node shared/db/prisma/seed.cjs",
    "db:migrate:deploy": "node src/scripts/run-migrations.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.9.0",
    "@shop/design-tokens": "workspace:*",
    "@shop/ui": "workspace:*",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@white-shop/db": "workspace:*",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "ioredis": "^5.3.2",
    "isomorphic-dompurify": "^3.0.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.555.0",
    "nanoid": "^5.1.6",
    "next": "^16.2.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.66.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/browser-image-compression": "^1.0.1",
    "@types/dompurify": "^3.2.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}