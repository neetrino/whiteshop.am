{
  "name": "marco.am",
  "version": "1.0.0",
  "private": true,
  "description": "Marco.am — Next.js app at root, pnpm workspace",
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --no-turbo",
    "dev:clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\" && next dev",
    "prebuild": "cd shared/db && pnpm run db:generate",
    "prebuild:migrate": "node src/scripts/run-migrations.js",
    "build": "pnpm run prebuild:migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\"",
    "prisma:generate": "cd shared/db && pnpm run db:generate",
    "reset":"node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\" && cd shared/db && pnpm run db:generate",
    "db:generate": "pnpm --filter @white-shop/db db:generate",
    "db:push": "pnpm --filter @white-shop/db db:push",
    "db:migrate": "pnpm --filter @white-shop/db db:migrate",
    "db:studio": "pnpm --filter @white-shop/db db:studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.9.0",
    "@shop/design-tokens": "workspace:*",
    "@shop/ui": "workspace:*",
    "@white-shop/db": "workspace:*",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.555.0",
    "meilisearch": "^0.38.0",
    "next": "^16.1.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.66.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/browser-image-compression": "^1.0.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
